generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id        String   @id @default(cuid())
  name      String
  capacity  Int      @default(2)
  status    String   @default("available") // available, full
  tenants   Tenant[]
  createdAt DateTime @default(now())
}

model Tenant {
  id          String    @id @default(cuid())
  fullName    String
  phoneNumber String
  university  String
  origin      String
  status      String // mahasiswa, alumni, tamu
  roomId      String?
  room        Room?     @relation(fields: [roomId], references: [id])
  payments    Payment[]
  createdAt   DateTime  @default(now())
}

model Registration {
  id              String   @id @default(cuid())
  fullName        String
  phoneNumber     String
  university      String?
  origin          String?
  gender          String
  status          String   @default("pending") // pending, approved, rejected
  rejectionReason String?
  tenantId        String? // Link to the created tenant
  createdAt       DateTime @default(now())
}

model Payment {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  amount      Int
  status      String    @default("unpaid") // unpaid, paid
  dueDate     DateTime
  periodStart DateTime?
  periodEnd   DateTime?
  createdAt   DateTime  @default(now())
}

model Pricing {
  id        String   @id @default(cuid())
  type      String   @unique // mahasiswa, alumni, tamu
  price     Int
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}
